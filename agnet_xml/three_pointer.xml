<mujoco model="three_pointer">
      <compiler angle="radian" inertiafromgeom="true" />
      <default>
            <joint armature="1" damping="1" limited="true" />
            <geom conaffinity="1" condim="3" contype="1" friction=".4 .1 .1"
                  rgba="0.8 0.6 .4 1" solimp="0.0 0.8 0.01" solref="0.02 1" />
      </default>
      <option gravity="0 0 -9.81" integrator="RK4" timestep="0.002" />

      <asset>
            <texture builtin="gradient" height="100" rgb1="1 1 1" rgb2="0 0 0"
                  type="skybox" width="100" />
            <texture builtin="checker" height="100" name="texplane"
                  rgb1="0 0 0" rgb2="0.8 0.8 0.8" type="2d" width="100" />
            <material name="MatPlane" reflectance="0.5" shininess="1" specular="1"
                  texrepeat="60 60" texture="texplane" />
      </asset>

      <worldbody>
            <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3"
                  directional="true" exponent="1" pos="0 0 5" specular=".1 .1 .1" />
            <geom conaffinity="1" condim="3" material="MatPlane" name="floor"
                  pos="0 0 0" rgba="0.8 0.9 0.8 1" size="40 40 40" type="plane" />

            <!-- Arena (visual only) -->
            <body name="combined_arena">
                  <camera name="track" mode="fixed" pos="0 -13 3.0" xyaxes="1 0 0 0 0 1" />
                  <geom type="cylinder" size="6 0.01" pos="0 0 0"
                        conaffinity="0" contype="0" rgba="0.87 0.73 0.52 1" />
                  <geom type="box" size="4 6 0.01" pos="3 0 0.001"
                        conaffinity="0" contype="0" rgba="0.87 0.73 0.52 1" />
            </body>

            <!-- Basketball Hoop (FIXED — removed sliding joints) -->
            <body name="basketball_hoop" pos="0 0 0">
                  <!-- Rim (visual only) -->
                  <geom type="cylinder" size="0.45 0.01" pos="6 0 3"
                        conaffinity="0" contype="0" rgba="1.0 0.4 0.0 1" />
                  <!-- Pole -->
                  <geom type="cylinder" size="0.05 1.6" pos="6.5 0 1.6"
                        conaffinity="1" contype="1" rgba="0.7 0.7 0.7 1" />
                  <!-- Target marker (small red sphere at hoop center for reward calc) -->
                  <geom type="sphere" size="0.119" pos="6 0 3"
                        conaffinity="0" contype="0" rgba="1 0 0 0.5" />
            </body>

            <!-- Arm (FIXED — arm geoms now collide contype=1) -->
            <body name="arm" pos="-6 0 1.3">
                  <joint axis="0 1 0" limited="false" name="joint0"
                        pos="0 0 0" type="hinge" damping="0.3" armature="0.0" />
                  <geom conaffinity="1" contype="1" fromto="0 -0.1 0 0 0.1 0"
                        name="root" rgba="1 0.0 0.0 1" size=".15" type="cylinder" />
                  <geom conaffinity="1" contype="1" fromto="0 0 0 0.75 0 0"
                        name="link0" rgba="0.0 0.4 0.6 1" size=".1" type="box"
                        mass="0.0001" />
            </body>

            <!-- Basketball (FIXED — starts at arm tip, not floating at z=5) -->
            <body name="basketball" pos="-5.5 0 0.12">
                  <freejoint name="ball_free" />
                  <geom conaffinity="1" contype="1" name="target" pos="0 0 0"
                        rgba="0.9 0.4 0.1 1" size=".12" mass="0.001" type="sphere" />
            </body>
      </worldbody>

      <actuator>
            <motor ctrllimited="true" ctrlrange="-1.0 1.0"
                  gear="5.0" joint="joint0" />
      </actuator>
      <!-- Add to your XML -->
      <equality>
            <weld name="ball_grip" body1="arm" body2="basketball"
                  relpose="0.85 0 0 1 0 0 0"
                  active="true" />
      </equality>
</mujoco>